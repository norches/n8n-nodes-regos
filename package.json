{
	"name": "n8n-nodes-regos",
	"version": "0.1.2",
	"description": "n8n community nodes for the REGOS SaaS ERP (retail, inventory, documents, POS, CRM)",
	"license": "MIT",
	"homepage": "https://github.com/norches/n8n-nodes-regos",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"regos",
		"erp",
		"retail",
		"pos"
	],
	"author": {
		"name": "norches",
		"email": "norches74@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/norches/n8n-nodes-regos.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"generate": "tsx scripts/generate/index.ts",
		"generate:check": "tsx scripts/generate/index.ts --check",
		"generate:diff": "tsx scripts/generate/index.ts --diff",
		"test": "vitest run",
		"test:watch": "vitest",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/RegosApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Regos/Regos.node.js",
			"dist/nodes/RegosDocuments/RegosDocuments.node.js",
			"dist/nodes/RegosPos/RegosPos.node.js",
			"dist/nodes/RegosCrm/RegosCrm.node.js",
			"dist/nodes/RegosReports/RegosReports.node.js",
			"dist/nodes/RegosTrigger/RegosTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.39.3",
		"@types/node": "^20.14.0",
		"eslint": "9.32.0",
		"n8n-workflow": "*",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"tsx": "^4.19.0",
		"typescript": "5.9.2",
		"vitest": "^3.2.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
